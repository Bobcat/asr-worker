# Optional worker environment overrides for user-level dev units.
# Copy to: ~/.config/asr-worker/asr-worker.dev.env
#
# Default queue base in the tracked dev unit:
#   ~/projects/omniscripta/data/upload/jobs/worker
# Override it here with your absolute local path when needed:
# ASR_WORKER_QUEUE_BASE=/home/you/projects/omniscripta/data/upload/jobs/worker
# ASR_WORKER_MAX_OUTSTANDING=4
# ASR_WORKER_CONSUMER_ID=worker-upload@1
